# LLM Configuration
# Choose provider: "groq" (default), "gemini", "openrouter", or "ollama"
LLM_PROVIDER_NAME=groq
GROQ_API_KEY=your_groq_api_key_here

# Model for the selected provider
# For Ollama, use your local model name (e.g., "local-llm-model")
# LLM_MODEL=local-llm-model

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional: comma-separated fallback models tried in order if the primary fails
# OPENROUTER_FALLBACK_MODELS=anthropic/claude-3.5-sonnet,gryphe/mythomax-l2-13b
# Optional: enable extended thinking/reasoning (supported models only)
# OPENROUTER_ENABLE_THINKING=true

# MongoDB Configuration
MONGODB_CONNECTION_STRING=mongodb://admin:memblocks123@localhost:27017/memblocks?authSource=admin

# Telemetry Configuration
ARIZE_SPACE_ID=your_space_id
ARIZE_API_KEY=your_api_key
ARIZE_PROJECT_NAME='memBlocks'

# Qdrant Configuration (default local)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Ollama Configuration (default local)
OLLAMA_BASE_URL=http://localhost:11434
# Dedicated endpoint for embedding requests (defaults to Docker-mapped embeddings service)
OLLAMA_BASE_URL_EMBEDDINGS=http://localhost:11435
# How long to keep models loaded: "10s", "5m", "1h", or "-1" for unlimited
OLLAMA_KEEP_ALIVE=10s

# Clerk Authentication (Google OAuth)
# Get these from your Clerk dashboard at https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here


#Cohere api key for reranking 
COHERE_API_KEY=your_cohere_api_key_here

# Optional: Enable Ollama chat model pulling during Docker build (default: false)
# OLLAMA_PULL_CHAT_MODEL=true
# OLLAMA_CHAT_MODEL=llama3:8b
# OLLAMA_LLM_ENABLED=true